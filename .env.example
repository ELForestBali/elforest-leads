# Скопируй этот файл в .env и заполни значениями
# НИКОГДА не загружай .env на GitHub — он только для локальной разработки

# Telegram MTProto (с my.telegram.org)
TG_API_ID=123456
TG_API_HASH=abcdef1234567890abcdef1234567890

# Строка сессии — получается через python auth.py
TG_SESSION_STRING=

# Telegram Bot (от BotFather)
BOT_TOKEN=123456789:AAHdqTcvCH...

# Куда слать алерты (твой Telegram ID)
ALERT_CHAT_ID=1024728900

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# База данных (Railway подставляет автоматически)
DATABASE_URL=postgresql://...

# Минимальный score для алерта (по умолчанию 6)
MIN_SCORE=6
